generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id             String         @id
  name           String
  inBody         InBodyRecord[]
  mealPlan       MealPlan?
  plannerEntries PlannerEntry[]
  carbFoods      CarbFood[]
}

model InBodyRecord {
  id                  String   @id @default(cuid())
  personId            String
  person              Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  date                String
  weight              Float?
  skeletalMuscleMass  Float?
  bodyFatMass         Float?
  bodyFatPercent      Float?
  bmi                 Float?
  visceralFatLevel    Int?
  bmr                 Int?
  recommendedCalories Int?
  waistHipRatio       Float?
  createdAt           DateTime @default(now())

  @@index([personId])
}

model Protein {
  id           String         @id @default(cuid())
  name         String
  lossPercent  Int            @default(0)
  notes        String?
  plannerEntries PlannerEntry[]
}

model MealPlan {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  slots    Json
}

model PlannerEntry {
  id          String        @id @default(cuid())
  weekStart   String
  personId    String
  person      Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  day         String
  slot        String
  proteinId   String?
  protein     Protein?      @relation(fields: [proteinId], references: [id], onDelete: SetNull)
  cookedGrams Int?
  carbs       PlannerCarb[]

  @@unique([weekStart, personId, day, slot])
  @@index([weekStart])
}

model CarbFood {
  id              String        @id @default(cuid())
  personId        String
  person          Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  name            String
  unitLabel       String
  unitsPerPortion Float
  notes           String?
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())

  plannerCarbs    PlannerCarb[]

  @@index([personId])
}

model PlannerCarb {
  id             String       @id @default(cuid())
  plannerEntryId String
  plannerEntry   PlannerEntry @relation(fields: [plannerEntryId], references: [id], onDelete: Cascade)
  carbFoodId     String
  carbFood       CarbFood     @relation(fields: [carbFoodId], references: [id], onDelete: Cascade)
  portions       Float

  @@index([plannerEntryId])
}

model ShoppingHave {
  id        String @id @default(cuid())
  weekStart String
  proteinId String

  @@unique([weekStart, proteinId])
}
